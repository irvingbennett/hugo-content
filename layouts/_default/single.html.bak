{{ define "main" }}

<article class="single-post">
  <header class="post-header">
    <h1 class="post-title">{{ .Title }}</h1>
    
    {{ if not .Date.IsZero }}
    <div class="post-meta" style="margin-bottom: 1.5rem; color: #888; font-size: 0.95rem;">
      <time datetime="{{ .Date.Format "2006-01-02" }}">
        📅 {{ .Date.Format "January 2, 2006" }}
      </time>
    </div>
    {{ end }}
  </header>

  <!-- Wrapping the content in 'post-body' targets only your text links -->
  <div class="post-content post-body">
    {{ .Content }}
  </div>
</article>
{{ end }}